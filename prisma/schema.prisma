generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  isAdmin       Boolean        @default(false)
  isActive      Boolean        @default(true)
  isApproved    Boolean        @default(true)
  displayName             String  @default("")
  personalRules           String  @default("")
  personalRulesNovel      String  @default("")
  personalRulesStory      String  @default("")
  rejectionReason         String  @default("")
  defaultTemperature      Float   @default(0.9)
  defaultFrequencyPenalty Float   @default(0.3)
  defaultMaxOutputTokens  Int     @default(8192)
  defaultThinkingBudget   Int     @default(0)
  defaultSafetyLevel      String  @default("standard")
  defaultAI               String  @default("gemini")
  theme                   String  @default("retro")
  characters    Character[]
  conversations Conversation[]
  characterCollections CharacterCollection[]
}

model RandomName {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   @default("korean")
  gender    String   @default("")
  createdAt DateTime @default(now())
}

model WorldTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

}

model StatTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model CharacterTag {
  id        String   @id @default(cuid())
  name      String
  category  String
  gender    String   @default("공통")
  createdAt DateTime @default(now())

  @@unique([name, category])
}

model GlobalConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CharacterCollection {
  id         String      @id @default(cuid())
  title      String
  sourceUrl  String      @default("")
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  characters Character[]
  createdAt  DateTime    @default(now())
}

model Character {
  id                  String    @id @default(cuid())
  name                String
  gender              String    @default("")
  avatarUrl           String?
  tags                String[]  @default([])
  additionalInfo      String    @default("")
  exampleDialogues    String    @default("")
  openingMessage      String    @default("")
  safetyLevel         String    @default("standard")
  temperature         Float     @default(0.9)
  frequencyPenalty    Float     @default(0.3)
  maxOutputTokens     Int       @default(8192)
  thinkingBudget      Int       @default(0)
  defaultAI           String    @default("gemini")
  isPreset            Boolean   @default(false)
  isAutoCreated       Boolean   @default(false)
  createdAt           DateTime  @default(now())
  creatorId           String?
  creator             User?     @relation(fields: [creatorId], references: [id])
  collectionId        String?
  collection          CharacterCollection? @relation(fields: [collectionId], references: [id])
  conversations       ConversationCharacter[]
  personaConversations Conversation[]
  lorebooks           Lorebook[]
}

model UploadedImage {
  id         String   @id @default(cuid())
  filename   String   @unique
  isShared   Boolean  @default(false)
  uploaderId String?
  createdAt  DateTime @default(now())
}

model Conversation {
  id              String                  @id @default(cuid())
  userId          String?
  user            User?                   @relation(fields: [userId], references: [id])
  title           String
  summary         String                  @default("")
  currentAI       String                  @default("gemini")
  personaCharacterId String?
  personaCharacter   Character?           @relation(fields: [personaCharacterId], references: [id])
  coreMemory          String                  @default("")
  statusTimeline      String                  @default("")
  scenarioDescription String                  @default("")
  mode                String                  @default("roleplay")
  tags                String[]
  temperature         Float                   @default(0.9)
  frequencyPenalty    Float                   @default(0.3)
  maxOutputTokens     Int                     @default(8192)
  thinkingBudget      Int                     @default(0)
  safetyLevel         String                  @default("standard")
  isPinned            Boolean                 @default(false)
  isArchived          Boolean                 @default(false)
  isSummarizing       Boolean                 @default(false)
  statsEnabled        Boolean                 @default(false)
  statsConfig         Json?
  inventoryEnabled    Boolean                 @default(false)
  inventory           Json?
  styleConfig         Json?
  isAutoCreated       Boolean                 @default(false)
  sourceUrl           String                  @default("")
  sourceLorebookUrls  Json?
  rootConversationId   String?
  branchFromMessageId  String?
  branchDescription    String                  @default("")
  characters      ConversationCharacter[]
  messages        Message[]
  memories        Memory[]
  lorebooks       Lorebook[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([userId, updatedAt])
}

model ConversationCharacter {
  conversationId String
  characterId    String
  turnOrder      Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  character      Character    @relation(fields: [characterId], references: [id])

  @@id([conversationId, characterId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  aiModel        String?
  characterId    String?
  parentId       String?
  isSelected     Boolean      @default(true)
  isStreaming    Boolean      @default(false)
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  inventoryDelta Json?
  statsDelta     Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, isSelected, isStreaming])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())
}

model Memory {
  id                 String       @id @default(cuid())
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary            String
  messageRangeStart  String
  messageRangeEnd    String
  embedding          Unsupported("vector(768)")?
  createdAt          DateTime     @default(now())
  promoted           Boolean      @default(false)

  @@index([conversationId, createdAt])
}

model Lorebook {
  id             String       @id @default(cuid())
  scope          String
  scopeId        String
  keyword        String[]
  content        String
  priority       Int          @default(0)
  scanDepth      Int          @default(5)
  isEnabled      Boolean      @default(true)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  characterId    String?
  character      Character?   @relation(fields: [characterId], references: [id])

  @@index([conversationId])
  @@index([scope, scopeId])
}

model AiErrorLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  userId         String   @default("")
  conversationId String   @default("")
  provider       String   @default("")
  mode           String   @default("")
  errorType      String   @default("")
  statusCode     Int      @default(0)
  message        String   @default("")
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)

  @@index([createdAt])
}

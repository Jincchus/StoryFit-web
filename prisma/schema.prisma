generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  isAdmin       Boolean        @default(false)
  isActive      Boolean        @default(true)
  isApproved    Boolean        @default(true)
  displayName             String  @default("")
  rejectionReason         String  @default("")
  defaultTemperature      Float   @default(0.9)
  defaultFrequencyPenalty Float   @default(0.3)
  defaultMaxOutputTokens  Int     @default(8192)
  defaultThinkingBudget   Int     @default(0)
  defaultSafetyLevel      String  @default("standard")
  defaultAI               String  @default("gemini")
  theme                   String  @default("whif")
  characters    Character[]
  conversations Conversation[]
  characterCollections CharacterCollection[]
  promptPresets PromptPreset[]
  pushTokens    PushToken[]
}

model PushToken {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      String
  name      String
  content   String
  enabled   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, mode])
}

model RandomName {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String   @default("korean")
  gender    String   @default("")
  createdAt DateTime @default(now())
}

model WorldTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

}

model StatTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model CharacterTag {
  id        String   @id @default(cuid())
  name      String
  category  String
  gender    String   @default("공통")
  createdAt DateTime @default(now())

  @@unique([name, category])
}

model GlobalConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CenterTag {
  id         String   @id @default(cuid())
  name       String   @unique
  category   String?
  searchable Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemId    String
  createdAt DateTime @default(now())

  @@unique([userId, itemType, itemId])
  @@index([userId])
}

model CharacterCollection {
  id             String        @id @default(cuid())
  title          String
  sourceUrl      String        @default("")
  userId         String
  conversationId String?       @unique
  user           User          @relation(fields: [userId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  characters     Character[]
  lorebooks      Lorebook[]
  coverImageUrl  String        @default("")
  description    String        @default("")
  tags           String[]      @default([])
  zetaMeta       Json?
  meltingMeta    Json?
  tikitaMeta     Json?
  tingleMeta     Json?
  chubMeta       Json?         // 번역 토글용: { activeLang: 'en'|'ko', alt: 비활성 언어 스냅샷 }
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([sourceUrl])
}

model Character {
  id                  String    @id @default(cuid())
  name                String
  gender              String    @default("")
  avatarUrl           String?
  tags                String[]  @default([])
  additionalInfo      String    @default("")
  exampleDialogues    String    @default("")
  openingMessage      String    @default("")
  openingMessages     Json?
  safetyLevel         String    @default("standard")
  temperature         Float     @default(0.9)
  frequencyPenalty    Float     @default(0.3)
  maxOutputTokens     Int       @default(8192)
  thinkingBudget      Int       @default(0)
  defaultAI           String    @default("gemini")
  relatedImages       String[]  @default([])
  isPreset            Boolean   @default(false)
  isAutoCreated       Boolean   @default(false)
  createdAt           DateTime  @default(now())
  creatorId           String?
  creator             User?     @relation(fields: [creatorId], references: [id])
  collectionId        String?
  collection          CharacterCollection? @relation(fields: [collectionId], references: [id])
  conversations       ConversationCharacter[]
  personaConversations Conversation[]

  @@index([creatorId])
  @@index([collectionId])
}

model UploadedImage {
  id         String   @id @default(cuid())
  filename   String   @unique
  isShared   Boolean  @default(false)
  uploaderId String?
  createdAt  DateTime @default(now())
}

model Conversation {
  id              String                  @id @default(cuid())
  userId          String?
  user            User?                   @relation(fields: [userId], references: [id])
  title           String
  currentAI       String                  @default("gemini")
  chatModel       String?                 // 대화별 Gemini 모델 선택(null = 기본 GEMINI_CHAT_MODEL)
  personaCharacterId String?
  personaCharacter   Character?           @relation(fields: [personaCharacterId], references: [id])
  coreMemory          String                  @default("")
  statusTimeline      String                  @default("")
  scenarioDescription String                  @default("")
  mode                String                  @default("roleplay")
  tags                String[]
  temperature         Float                   @default(0.9)
  frequencyPenalty    Float                   @default(0.3)
  maxOutputTokens     Int                     @default(8192)
  thinkingBudget      Int                     @default(0)
  safetyLevel         String                  @default("standard")
  isPinned            Boolean                 @default(false)
  isArchived          Boolean                 @default(false)
  isSummarizing       Boolean                 @default(false)
  statsEnabled        Boolean                 @default(false)
  statsConfig         Json?
  inventoryEnabled    Boolean                 @default(false)
  inventory           Json?
  styleConfig         Json?
  chapter                Int                  @default(1)
  plotOutline            Json?
  suggestRepliesEnabled  Boolean              @default(false)
  enrichInputMode        Boolean              @default(false)
  personaAutoMode        Boolean              @default(false)
  personaFlipPlaceholders Boolean              @default(true)
  autoChapterEnabled     Boolean              @default(false)
  isAutoCreated       Boolean                 @default(false)
  sourceUrl           String                  @default("")
  sourceLorebookUrls  Json?
  rootConversationId   String?
  branchFromMessageId  String?
  branchDescription    String                  @default("")
  characters          ConversationCharacter[]
  messages            Message[]
  memories            Memory[]
  lorebooks           Lorebook[]
  characterCollection CharacterCollection?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([userId, updatedAt])
}

model ConversationCharacter {
  conversationId String
  characterId    String
  turnOrder      Int          @default(0)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  character      Character    @relation(fields: [characterId], references: [id])

  @@id([conversationId, characterId])
  @@index([characterId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  aiModel        String?
  characterId    String?
  parentId       String?
  isSelected     Boolean      @default(true)
  isStreaming    Boolean      @default(false)
  inputTokens    Int          @default(0)
  outputTokens   Int          @default(0)
  inventoryDelta Json?
  statsDelta     Json?
  bookmarked     Boolean      @default(false)
  chapter        Int          @default(1)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, isSelected, isStreaming])
  @@index([conversationId, chapter])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  detail    String   @default("")
  createdAt DateTime @default(now())
}

model Memory {
  id                 String       @id @default(cuid())
  conversationId     String
  conversation       Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  summary            String
  messageRangeStart  String
  messageRangeEnd    String
  embedding          Unsupported("vector(768)")?
  createdAt          DateTime     @default(now())
  promoted           Boolean      @default(false)

  @@index([conversationId, createdAt])
}

model Lorebook {
  id             String       @id @default(cuid())
  keyword        String[]
  content        String
  priority       Int          @default(0)
  scanDepth      Int          @default(5)
  isEnabled      Boolean      @default(true)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  collectionId   String?
  collection     CharacterCollection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([collectionId])
}

model AiErrorLog {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  userId         String   @default("")
  conversationId String   @default("")
  provider       String   @default("")
  mode           String   @default("")
  errorType      String   @default("")
  statusCode     Int      @default(0)
  message        String   @default("")
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)

  @@index([createdAt])
}
